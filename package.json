{
  "name": "pi-network",
  "version": "1.0.0",
  "description": "Turn multiple Pi coding agents into a coordinated agent mesh with smart delegation, file locking, and chain-of-custody result tracking.",
  "main": "src/extension.ts",
  "scripts": {
    "build": "tsc",
    "relay": "npx tsx src/relay.ts",
    "claude-bridge": "npx tsx src/claude-bridge.ts",
    "dev": "npx tsx src/extension.ts"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": ">=1.0.0",
    "@mariozechner/pi-ai": ">=1.0.0"
  },
  "pi": {
    "extensions": ["./src/extension.ts"]
  },
  "keywords": [
    "pi",
    "coding-agent",
    "agent-mesh",
    "delegation",
    "tailscale",
    "mcp"
  ],
  "author": "jamezun",
  "license": "MIT",
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "@types/ws": "^8.5.0",
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0"
  }
}
